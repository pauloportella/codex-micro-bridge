#!/bin/sh
set -eu

product=$1
shift
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
project_root=$(dirname "$script_dir")

if ! command -v swift >/dev/null 2>&1; then
  echo "Swift is required. Install the Xcode Command Line Tools." >&2
  exit 1
fi

bin_path=$(swift build --package-path "$project_root" -c release --show-bin-path)
binary="$bin_path/$product"

if [ ! -x "$binary" ] || \
   find "$project_root/Package.swift" "$project_root/Sources" \
     -type f -newer "$binary" -print -quit | grep -q .; then
  swift build --package-path "$project_root" -c release --product "$product"
fi

export CODEX_MICRO_BRIDGE_ROOT="$project_root"
exec "$binary" "$@"
